# SwiftSteps 자동화 설정 파일
# 이 파일을 .env 로 복사한 후 값을 채워주세요
# cp .env.example .env

# Anthropic API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=sk-ant-여기에_API_키_입력

# Obsidian Vault 절대 경로
# 예시 (Mac): /Users/사용자이름/Documents/SwiftSteps
# 예시 (Windows): C:\Users\사용자이름\Documents\SwiftSteps
OBSIDIAN_VAULT_PATH=/Users/사용자이름/Documents/SwiftSteps
