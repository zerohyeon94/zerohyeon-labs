# SwiftSteps Codex 자동화 설정 파일
# 이 파일을 .env 로 복사한 후 값을 채워주세요
# cp .env.example .env

# Obsidian Vault 절대 경로
# 예시 (Mac): /Users/사용자이름/Documents/Develop/zerohyeon-labs
# 예시 (Windows): C:\Users\사용자이름\Documents\SwiftSteps
OBSIDIAN_VAULT_PATH=/Users/사용자이름/Documents/Develop/zerohyeon-labs

# 선택: Codex 실행 파일과 모델을 지정하고 싶을 때만 사용
CODEX_BIN=codex
CODEX_MODEL=
